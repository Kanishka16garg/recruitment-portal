# Backend Environment Variables
# Copy this file to config/config.env and fill in your actual values

PORT=4000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/JOB_PORTAL_WITH_AUTOMATION?retryWrites=true&w=majority

# JWT
JWT_SECRET_KEY=your_secret_key_here_change_in_production
JWT_EXPIRE=5d
COOKIE_EXPIRE=5

# Cloudinary (for resume uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP (for email notifications)
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_MAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# For Production Deployment (Render/Railway/Heroku)
# Set NODE_ENV=production
# Use HTTPS in FRONTEND_URL
# Update MONGO_URI to production DB
# Update JWT_SECRET_KEY to a strong random value
# Use transactional email service (SendGrid/Mailgun) instead of Gmail
